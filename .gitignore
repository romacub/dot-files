# Ignore all files and directories recursively, except for configured ones:
/**

# Allow the .config directory itself
!.config/

# Allow the specific subdirectories (the directories themselves)
!.config/nvim/
!.config/tmux/
!.config/kitty/

# Then allow everything inside those directories
!.config/nvim/**
!.config/tmux/**
!.config/kitty/**

# And apps configured outside of .config
!.zshrc

# And except for git files
!.gitignore
!README.md

# But ignore tmux plugins and logs
.config/tmux/plugins/
.config/tmux/tmux-*.log

# Ignore lazy lock
.config/nvim/lazy-lock.json
