# Rosé Pine
include current-theme.conf

font_size 14
font_family      family="CaskaydiaCove Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto


cursor_shape block
cursor_shape_unfocused hollow
cursor_trail 1
cursor_trail_decay 0.2 0.3
cursor_trail_start_threshold 6

scrollbar scrolled-and-hovered
scrollbar_jump_on_click yes

touch_scroll_multiplier 5
# touchpad_scroll_multiplier 5.0
# scrollback_lines 5000
mouse_hide_wait 0

copy_on_select clipboard
clear_selection_on_clipboard_loss yes
paste_actions replace-dangerous-control-codes,confirm-if-large
strip_trailing_spaces smart

repaint_delay 10
input_delay 1
sync_to_monitor no

inactive_text_alpha 0.3

confirm_os_window_close -1

editor nvim

enable_audio_bell no
linux_display_server wayland

background_opacity 0.65
background_blur 1

# input "your_touchpad_device_name" {
#     natural_scroll enabled
# }
